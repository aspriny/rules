function main(params) {

  // 创建代理组的辅助函数
  function createProxyGroup(name, type, icon, proxies) {
    return {
      name,
      type,
      url: "http://www.gstatic.com/generate_204",
      icon,
      interval: 300,
      tolerance: type === "url-test" ? 20 : undefined,
      timeout: type === "url-test" ? 2000 : undefined,
      lazy: true,
      proxies: proxies.length > 0 ? proxies : ["DIRECT"],
      strategy: type === "load-balance" ? "consistent-hashing" : undefined
    };
  }

  // 通过正则过滤节点
  function getProxiesByRegex(params, regex) {
    return params.proxies
      .filter(e => regex.test(e.name))
      .map(e => e.name);
  }

  // 1. 定义区域自动分组
  const regions = [
    { name: "HongKong", type: "select", regex: /香港|HK|hk|Hong|🇭🇰/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Hong_Kong.png" },
    { name: "TaiWan", type: "select", regex: /台湾|TW|Taiwan|Wan|🇨🇳|🇹🇼/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Taiwan.png" },
    { name: "Singapore", type: "select", regex: /新加坡|狮城|SG|sg|Singapore|🇸🇬/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Singapore.png" },
    { name: "Japan", type: "select", regex: /日本|JP|jp|Japan|🇯🇵/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Japan.png" },
    { name: "America", type: "select", regex: /美国|US|us|United States|America|🇺🇸/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/United_States.png" },
    { name: "Auto", regex: /^(?!.*(?:自动|故障|流量|官网|套餐|机场|订阅|年|月|失联|频道)).*$/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Auto.png", type: "url-test" },
    { name: "Balance", regex: /^(?!.*(?:自动|故障|流量|官网|套餐|机场|订阅|年|月|失联|频道)).*$/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Available.png", type: "load-balance" },
    { name: "Fallback", regex: /^(?!.*(?:自动|故障|流量|官网|套餐|机场|订阅|年|月|失联|频道)).*$/, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Bypass.png", type: "fallback" }
  ];

  const proxyGroups = regions.map(region =>
    createProxyGroup(region.name, region.type || "url-test", region.icon, getProxiesByRegex(params, region.regex))
  );

  // 获取所有节点列表供 Manual 和 Proxy 使用
  const allProxies = [...new Set(proxyGroups.flatMap(g => g.proxies))];

  // 2. 预定义策略组
  const predefinedGroups = [
    { name: "Proxy", type: "select", proxies: allProxies, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Proxy.png" },
    { name: "Manual", type: "select", proxies: allProxies, icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Proxy.png" },
    { name: "AI", type: "select", proxies: ["Proxy", "Manual", "America", "Japan", "Singapore", "TaiWan", "HongKong"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/ChatGPT.png" },
    { name: "YouTube", type: "select", proxies: ["Proxy", "Auto", "Balance", "Fallback", "HongKong", "TaiWan", "Singapore", "Japan", "America"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/YouTube.png" },
    { name: "Telegram", type: "select", proxies: ["Proxy", "Auto", "Balance", "Fallback", "HongKong", "TaiWan", "Singapore", "Japan", "America"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Telegram.png" },
    { name: "Google", type: "select", proxies: ["Proxy", "Auto", "Balance", "Fallback", "HongKong", "TaiWan", "Singapore", "Japan", "America"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Google.png" },
    { name: "Streaming", type: "select", proxies: ["Proxy", "Manual", "Auto", "Balance", "Fallback", "HongKong", "TaiWan", "Singapore", "Japan", "America"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/ForeignMedia.png" },
    { name: "Emby", type: "select", proxies: ["DIRECT", "Proxy", "Manual", "America", "Japan", "Singapore", "TaiWan", "HongKong"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Emby.png" },
    { name: "EmbyVIP", type: "select", proxies: ["DIRECT", "Proxy", "Manual", "America", "Japan", "Singapore", "TaiWan", "HongKong"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Emby.png" },

    { name: "BiliBili", type: "select", proxies: ["DIRECT", "HongKong", "TaiWan"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/bilibili.png" },
    { name: "Games", type: "select", proxies: ["Proxy", "Auto", "Balance", "Fallback", "HongKong", "TaiWan", "Singapore", "Japan", "America"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Game.png" },
    { name: "Mainland", type: "select", proxies: ["DIRECT", "Proxy", "Auto", "Balance", "Fallback", "HongKong", "TaiWan", "Singapore", "Japan", "America"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Round_Robin.png" },
    { name: "Global", type: "select", proxies: ["Proxy", "Manual", "Auto", "Balance", "Fallback", "HongKong", "TaiWan", "Singapore", "Japan", "America"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Global.png" },
    { name: "Final", type: "select", proxies: ["DIRECT", "Global", "Proxy"], icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Final.png" }
  ];

  params["proxy-groups"] = [...predefinedGroups, ...proxyGroups];

  // 3. 规则设置 (保持不变)
  params.rules = [
    "AND,(AND,(DST-PORT,443),(NETWORK,UDP)),(NOT,((GEOIP,CN,no-resolve))),REJECT",
    "GEOSITE,Private,DIRECT",
    "DOMAIN,emby.oceancloud.asia,Emby",
    "DOMAIN,panel.aemby.de,Emby",
    "DOMAIN,test.1huanlesap02.top,EmbyVIP",
    "DOMAIN,best.28.al,Emby",
    "DOMAIN,test.startspoint.com,Emby",
    "DOMAIN-SUFFIX,91porny.com,Manual",

    "RULE-SET,OpenAI,AI",
    "RULE-SET,Gemini,AI",
    "GEOSITE,Category-games@cn,Mainland",
    "GEOSITE,Category-games,Games",
    "GEOSITE,Github,Global",
    "GEOIP,Telegram,Telegram,no-resolve",
    "GEOSITE,Bilibili,BiliBili",
    "GEOSITE,Youtube,YouTube",
    "GEOSITE,Disney,Streaming",
    "GEOSITE,Netflix,Streaming",
    "GEOSITE,Google,Google",
    "GEOSITE,Microsoft@cn,Mainland",
    "GEOSITE,Apple@cn,Mainland",
    "GEOSITE,Geolocation-!cn,Global",
    "GEOSITE,CN,Mainland",
    "GEOIP,CN,Mainland,no-resolve",
    "DOMAIN-SUFFIX,bitmovin.com,Proxy",
    "DOMAIN-SUFFIX,formula1.com,Proxy",
    "DOMAIN-SUFFIX,opin.media,Proxy",
    "DOMAIN-SUFFIX,formula1.my.site.com,Proxy",
    "DOMAIN-SUFFIX,f1accountprod.report-uri.com,Proxy",
    "DOMAIN-SUFFIX,formula1.my.salesforce-scrt.com,Proxy",
    "DOMAIN-SUFFIX,tiled.media,Proxy",
    "DOMAIN-SUFFIX,mobile-collector.newrelic.com,Proxy",
    "DOMAIN-SUFFIX,f1prodlive.akamaized.net,Proxy",
    "DOMAIN-SUFFIX,d2n9h2wits23hf.cloudfront.net,Proxy",
    "DOMAIN-SUFFIX,f1esports.com,Proxy",
    "DOMAIN-SUFFIX,f1manager.com,Proxy",
    "DOMAIN-SUFFIX,f1play.com,Proxy",
    "DOMAIN-SUFFIX,f1.ascendon.tv,Proxy",
    "MATCH,Final"
  ];

  // 4. Rule Providers (保持不变)
  params["rule-providers"] = {
    "OpenAI": {
      "type": "http",
      "behavior": "domain",
      "url": "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/OpenAI/OpenAI.yaml",
      "interval": 86400,
      "format": "yaml"
    },
    "Gemini": {
      "type": "http",
      "behavior": "domain",
      "url": "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Gemini/Gemini.yaml",
      "interval": 86400,
      "format": "yaml"
    }
  };

  return params;
}